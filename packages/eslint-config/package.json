		"eslint-plugin-oxlint": "1.72.0",
		"eslint-plugin-sonarjs": "4.1.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"eslint": "10.6.0",
		"typescript-eslint": "8.62.1"
	},
	"peerDependencies": {
		"eslint": "^10.0.0",
		"typescript": ">=5.0.0",
		"typescript-eslint": "^8.62.0"
	}
