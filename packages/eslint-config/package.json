{
	"name": "@f0rbit/eslint-config",
	"version": "0.1.4",
	"description": "The thin typed ESLint layer of the f0rbit two-layer lint model — define_lint_config factory with per-repo naming presets",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/f0rbit/lint.git",
		"directory": "packages/eslint-config"
	},
	"files": [
		"src",
		"README.md"
	],
