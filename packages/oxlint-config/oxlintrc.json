{
	"ignorePatterns": ["**/node_modules/**", "**/dist/**", "**/coverage/**"],
	"plugins": ["typescript", "unicorn", "import", "oxc"],
	"categories": {
		"correctness": "error",
		"suspicious": "error"
	},
	"rules": {
		"unicorn/filename-case": ["error", { "case": "kebabCase" }],
		"typescript/no-explicit-any": "error",
		"typescript/no-non-null-assertion": "error",
		"max-depth": ["error", { "max": 5 }],
		"no-else-return": "error",
		"import/no-self-import": "error",
		// Decision log: the testing substrate re-exports fast-check's default export as a namespace — member access like fc.record(...) is the mandated pattern, which this rule cannot tell apart from a mistaken named-as-default access.
		"import/no-named-as-default-member": "off"
	}
}
