{
	"name": "lint-monorepo",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"lint": "oxlint . && eslint .",
		"lint:fix": "oxlint --fix . && eslint --fix .",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"verify": "bun run typecheck && bun test && bun run lint && bun run fmt:check"
	},
	"devDependencies": {
		"@f0rbit/lint": "workspace:*",
		"@types/bun": "1.3.14",
		"typescript": "6.0.3"
	}
}
