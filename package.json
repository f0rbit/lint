{
	"name": "lint-monorepo",
	"private": true,
	"type": "module",
	"workspaces": ["packages/*"],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"lint": "oxlint . && eslint .",
		"lint:fix": "oxlint --fix . && eslint --fix .",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"verify": "bun run typecheck && bun test"
	},
	"devDependencies": {
		"@types/bun": "1.3.14",
		"typescript": "6.0.3"
	}
}
