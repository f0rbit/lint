{
	"compilerOptions": {
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["bun"]
	},
	"include": ["packages/*/src/**/*.ts", "packages/*/tests/**/*.ts", "tests/**/*.ts", "eslint.config.ts"]
}
